# ---- Rust build artifacts ----
/target/
**/target/
**/*.rs.bk
*.pdb

# Note: Cargo.lock IS committed. This is an application crate
# shipping 7 binaries — a committed lockfile gives reproducible
# builds for end users and is the standard guidance from the Cargo
# book.

# ---- Documentation & benchmark artifacts ----
/target/doc/
/criterion/
/perf.data*
*.flamegraph
*.prof
*.heapdump

# ---- Claude Code context files (NEVER commit) ----
# CLAUDE.md provides cross-session context to the Claude agent. It lives
# at the PARENT of this repo (rvt-recon-2026-04-19/CLAUDE.md), not
# inside the repo. This entry is a defensive guard in case anyone
# copies or symlinks it here.
CLAUDE.md
.claude/*.local.md
.claude/*.local.json
# Claude Code spawns isolated git worktrees here when agents run —
# never commit them (they're embedded git repos on throwaway branches).
.claude/worktrees/

# ---- Local draft / personal content (NEVER commit) ----
# Outreach emails, internal decision memos, personal notes,
# anything that shouldn't be readable by strangers on the
# internet.
docs/outreach/
docs/announcement-draft.md
docs/drafts/
docs/_local/
drafts/
*.draft.md
*.private.md

# ---- Log files ----
*.log
/logs/

# ---- Environment / local overrides ----
.env
.env.*
!.env.example
*.local.toml
*.local.yaml
config.local.*

# ---- Editor / IDE ----
.vscode/
.idea/
.nvim/
.zed/
*.swp
*.swo
*.swn
*~
\#*\#
.\#*

# ---- OS cruft ----
.DS_Store
.DS_Store?
._*
.AppleDouble
.LSOverride
.Spotlight-V100
.Trashes
ehthumbs.db
ehthumbs_vista.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ---- Generated / backup ----
*.orig
*.rej
*.bak
*.old
*.tmp

# ---- Python (in case we add tooling) ----
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
*.egg-info/
.pytest_cache/

# ---- Node (in case we add JS tooling) ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Test-corpus RFA files (if ever vendored locally) ----
# The phi-ag/rvt LFS corpus lives outside this repo; if someone
# drops sample files into a local samples/ dir for testing,
# keep them out of git.
/samples/
/test-files/
*.rvt
*.rfa
*.rte
*.rft
!docs/**/*.rvt.md
